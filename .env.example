# Copy this file to .env (gitignored) and fill in real values.

# --- Prototype password gate (HTTP Basic Auth) ---
# A single shared username/password protects the deployed app. The container
# generates its password file from these at startup; BASIC_AUTH_PASSWORD is
# required (the app refuses to boot without it).
BASIC_AUTH_USER="preview"
BASIC_AUTH_PASSWORD="change-me-or-else-things-will-explode"

# --- Legacy AI Studio variables (not used by this static SPA) ---
# Kept for reference; the app is fully client-side and needs no API keys.
# GEMINI_API_KEY="MY_GEMINI_API_KEY"
# APP_URL="MY_APP_URL"
